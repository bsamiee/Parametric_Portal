{
    "name": "parametric-portal",
    "version": "0.4.0",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*",
        "apps/*/*",
        "packages/*"
    ],
    "scripts": {
        "prepare": "lefthook install",
        "test": "vitest run",
        "quality": "pnpm exec nx run-many -t typecheck,check --parallel=4 && npx knip && npx sherif",
        "dotnet": "bash tools/scripts/dotnet-check.sh",
        "python": "bash tools/scripts/python-check.sh"
    },
    "devDependencies": {
        "@anthropic-ai/tokenizer": "catalog:",
        "@berenddeboer/nx-biome": "catalog:",
        "@biomejs/biome": "catalog:",
        "@effect/experimental": "catalog:",
        "@effect/platform-browser": "catalog:",
        "@effect/vitest": "catalog:",
        "@mermaid-js/mermaid-cli": "catalog:",
        "@nx-extend/pulumi": "catalog:",
        "@nx-tools/nx-container": "catalog:",
        "@nx/docker": "catalog:",
        "@nx/dotnet": "catalog:",
        "@nx/js": "catalog:",
        "@nx/playwright": "catalog:",
        "@nx/react": "catalog:",
        "@nx/vite": "catalog:",
        "@nxlv/python": "catalog:",
        "@octokit/rest": "catalog:",
        "@playwright/test": "catalog:",
        "@radix-ui/react-label": "catalog:",
        "@radix-ui/react-separator": "catalog:",
        "@radix-ui/react-slot": "catalog:",
        "@rollup/plugin-typescript": "catalog:",
        "@stryker-mutator/core": "catalog:",
        "@stryker-mutator/typescript-checker": "catalog:",
        "@stryker-mutator/vitest-runner": "catalog:",
        "@swc-node/register": "catalog:",
        "@swc/core": "catalog:",
        "@tailwindcss/vite": "catalog:",
        "@tanstack/react-table": "catalog:",
        "@tanstack/react-virtual": "catalog:",
        "@types/k6": "catalog:",
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "@vitejs/plugin-react": "catalog:",
        "@vitest/browser-playwright": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "@vitest/ui": "catalog:",
        "babel-plugin-react-compiler": "catalog:",
        "browserslist": "catalog:",
        "class-variance-authority": "catalog:",
        "clsx": "catalog:",
        "cmdk": "catalog:",
        "date-fns": "catalog:",
        "effect": "catalog:",
        "fast-check": "catalog:",
        "happy-dom": "catalog:",
        "immer": "catalog:",
        "jsdom": "catalog:",
        "jspdf": "catalog:",
        "jszip": "catalog:",
        "knip": "catalog:",
        "lefthook": "catalog:",
        "lightningcss": "catalog:",
        "lucide-react": "catalog:",
        "nx": "catalog:",
        "react-aria": "catalog:",
        "react-compiler-runtime": "catalog:",
        "react-stately": "catalog:",
        "rollup-plugin-visualizer": "catalog:",
        "sharp": "catalog:",
        "sherif": "catalog:",
        "tailwind-merge": "catalog:",
        "tailwindcss": "catalog:",
        "testcontainers": "catalog:",
        "tslib": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vite-plugin-compression": "catalog:",
        "vite-plugin-csp": "catalog:",
        "vite-plugin-image-optimizer": "catalog:",
        "vite-plugin-inspect": "catalog:",
        "vite-plugin-pwa": "catalog:",
        "vite-plugin-svgr": "catalog:",
        "vite-plugin-webfont-dl": "catalog:",
        "vite-tsconfig-paths": "catalog:",
        "vitest": "catalog:",
        "zustand": "catalog:"
    },
    "browserslist": [
        "baseline widely available",
        "not dead",
        "not ie <= 11"
    ],
    "engines": {
        "node": "25.6.1"
    },
    "knip": {
        "ignoreBinaries": [
            "hadolint"
        ],
        "ignoreFiles": [
            "apps/kargadan/plugin/scripts/package-yak.ts"
        ],
        "ignoreIssues": {
            "apps/kargadan/harness/src/protocol/schemas.ts": [
                "types"
            ],
            "packages/devtools/src/client.ts": [
                "types"
            ]
        },
        "workspaces": {
            ".": {
                "entry": [
                    ".github/scripts/*.ts",
                    "tools/scripts/*.ts"
                ],
                "ignoreDependencies": [
                    "^@(fast-check|mermaid-js|octokit|radix-ui|tanstack)/",
                    "^@effect/(experimental|platform-browser|vitest)$",
                    "^@nx/(js|react)$",
                    "^@(nx-extend/pulumi|nx-tools/nx-container|nxlv/python)$",
                    "^@types/(k6|react|react-dom)$",
                    "^(babel-plugin-react-compiler|browserslist|class-variance-authority|clsx|cmdk|date-fns|fast-check|immer|jspdf|jszip|lucide-react|react-aria|react-compiler-runtime|react-stately|tailwind-merge|tailwindcss|testcontainers|zustand)$"
                ]
            },
            "infrastructure": {
                "entry": [
                    "src/platform.ts"
                ]
            },
            "packages/database": {
                "entry": [
                    "migrations/*.ts"
                ]
            }
        }
    },
    "packageManager": "pnpm@10.30.1",
    "pnpm": {
        "overrides": {
            "jiti": "2.6.1",
            "node-forge": "1.3.3",
            "puppeteer": "24.34.0",
            "axios": "1.13.5",
            "rollup": "^4.59.0",
            "koa": "^3.1.2",
            "minimatch@^10": "^10.2.4",
            "svgo": "^3.3.3",
            "tar@^7": "^7.5.10"
        },
        "peerDependencyRules": {
            "allowedVersions": {
                "puppeteer": "24.34.0",
                "typescript": "6.0.0-dev.20251125",
                "vitest": "4.0.18"
            }
        }
    }
}
