{
    "name": "@parametric-portal/kargadan-harness",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "bin": {
        "kargadan": "./dist/main.js"
    },
    "scripts": {
        "build": "vite build",
        "check": "biome check .",
        "cli": "tsx src/cli.ts",
        "cli:run": "tsx src/cli.ts run",
        "dev": "tsx watch src/cli.ts",
        "release": "tsx src/build-release.ts",
        "smoke:packaged": "tsx src/smoke-release.ts"
    },
    "nx": {
        "targets": {
            "release": {
                "cache": false,
                "dependsOn": ["build", "yak:package"],
                "inputs": [
                    "default",
                    { "env": "KARGADAN_RELEASE_DATABASE_DIGEST" },
                    { "env": "KARGADAN_RELEASE_DATABASE_IMAGE" }
                ],
                "outputs": ["{projectRoot}/dist/release"]
            },
            "smoke:packaged": {
                "cache": false,
                "dependsOn": ["release"],
                "inputs": [
                    "default",
                    { "env": "KARGADAN_RELEASE_DATABASE_DIGEST" },
                    { "env": "KARGADAN_RELEASE_DATABASE_IMAGE" }
                ]
            },
            "smoke:source": {
                "cache": false,
                "executor": "nx:run-commands",
                "options": {
                    "command": "pnpm exec vitest run --root . --project root-tests tests/integration/kargadan/phase8-cli-smoke.spec.ts tests/integration/kargadan/phase8-config.spec.ts tests/integration/kargadan/phase8-credentials.spec.ts tests/integration/kargadan/phase8-schemas.spec.ts"
                }
            },
            "yak:package": {
                "cache": false,
                "dependsOn": ["ParametricPortal.Kargadan.Plugin:build:release"],
                "executor": "nx:run-commands",
                "options": {
                    "command": "pnpm exec tsx apps/kargadan/plugin/scripts/package-yak.ts"
                }
            }
        }
    },
    "dependencies": {
        "@effect/cli": "catalog:",
        "@effect/platform": "catalog:",
        "@effect/platform-node": "catalog:",
        "@effect/sql": "catalog:",
        "@effect/workflow": "catalog:",
        "@parametric-portal/ai": "workspace:*",
        "@parametric-portal/database": "workspace:*",
        "effect": "catalog:"
    },
    "devDependencies": {
        "@effect/vitest": "catalog:",
        "@types/node": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    }
}
