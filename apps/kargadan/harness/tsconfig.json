{
    "compilerOptions": {
        "composite": false,
        "declaration": false,
        "declarationMap": false,
        "emitDeclarationOnly": false,
        "noEmit": true,
        "outDir": "dist",
        "paths": {
            "@parametric-portal/ai": ["../../../packages/ai/src/service.ts"],
            "@parametric-portal/ai/*": ["../../../packages/ai/src/*"],
